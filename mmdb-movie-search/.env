# MongoDB Atlas Connection String
# Lab Setup: Set your connection string here
MONGODB_URI=

# Database Configuration
DATABASE_NAME=sample_mflix
COLLECTION_NAME=movies
EMBEDDED_COLLECTION_NAME=embedded_movies
EMBEDDING_FIELD_NAME=plot_embedding_voyage_3_large

# Atlas Search Index
# Lab Setup: Set the name as movie-search
SEARCH_INDEX_NAME=movie-search
AUTOCOMPLETE=false
FACETS=false

# Atlas Vector Search Configuration
# Lab Setup: Specify vector search index name, API key, embedding model, and re-ranking model
VECTOR=false
VECTOR_SEARCH_INDEX_NAME=
VOYAGE_API_KEY=
VECTOR_EMBEDDING_MODEL=
RERANKING_MODEL=

# AI Lab Configuration
# Lab Setup: Specify Gemini API key, LLM model, and memory collection name
RAG=false
AGENTIC=false
MEMORY=false
GEMINI_API_KEY=
LLM_MODEL=
MEMORY_COLLECTION_NAME=

# Server Configuration
PORT=3000
HOST=localhost

